#!/bin/sh
#
# Auto-bump plugin patch version when plugin content changes are committed.
# Install: git config core.hooksPath .githooks  (or run: sh scripts/setup.sh)
#

# --- Git LFS delegation (defensive, LFS not currently in use) ---
if command -v git-lfs >/dev/null 2>&1; then
    git lfs pre-commit "$@" 2>/dev/null || true
fi

# --- Skip during rebase to avoid multiple version bumps ---
GIT_DIR="$(git rev-parse --git-dir)"
if [ -d "$GIT_DIR/rebase-merge" ] || [ -d "$GIT_DIR/rebase-apply" ]; then
    exit 0
fi

# --- Plugin version auto-bump ---
REPO_ROOT="$(git rev-parse --show-toplevel)"
PLUGIN_BASE="$REPO_ROOT/claude"

[ -d "$PLUGIN_BASE" ] || exit 0

STAGED_FILES=$(git diff --cached --name-only)

for plugin_dir in "$PLUGIN_BASE"/*/; do
    [ -d "$plugin_dir" ] || continue

    plugin_name=$(basename "$plugin_dir")

    # zelda-sounds is now GENERATED from plugins/zelda-sounds/ by build.mjs. Its
    # version is owned by plugins/zelda-sounds/manifest.json (the generated
    # claude/zelda-sounds/.claude-plugin/plugin.json is emitted from it), so it is
    # excluded from this legacy auto-bump loop and handled by the generated-plugin
    # step below. amplify is extracted to WeZZard/amplify (release PR only).
    # skill-kit keeps hand-edited auto-bump until v2 extract.
    if [ "$plugin_name" = "zelda-sounds" ] || [ "$plugin_name" = "amplify" ]; then
        continue
    fi

    plugin_json="$plugin_dir.claude-plugin/plugin.json"
    relative_plugin_json="claude/$plugin_name/.claude-plugin/plugin.json"

    [ -f "$plugin_json" ] || continue

    has_content_changes=false
    for f in $STAGED_FILES; do
        case "$f" in
            claude/$plugin_name/*)
                has_content_changes=true
                break
                ;;
        esac
    done

    if [ "$has_content_changes" = true ]; then
        current_version=$(sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$plugin_json")

        if [ -z "$current_version" ]; then
            echo "[auto-bump] WARNING: Could not read version from $relative_plugin_json, skipping"
            continue
        fi

        # Get the HEAD version, trying the current path first
        head_version=$(git show HEAD:"$relative_plugin_json" 2>/dev/null | sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')

        # If not found at current path, look for a rename source
        if [ -z "$head_version" ]; then
            old_path=$(git diff --cached -M --diff-filter=R --name-status 2>/dev/null | awk -F'\t' -v new="$relative_plugin_json" '$NF == new {print $(NF-1)}')
            if [ -n "$old_path" ]; then
                head_version=$(git show HEAD:"$old_path" 2>/dev/null | sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
            fi
        fi

        # New plugin (no HEAD version at all) — respect the initial version
        if [ -z "$head_version" ]; then
            continue
        fi

        # Version was manually changed — respect it
        if [ "$head_version" != "$current_version" ]; then
            continue
        fi

        # Auto-bump patch version
        major=$(echo "$current_version" | cut -d. -f1)
        minor=$(echo "$current_version" | cut -d. -f2)
        patch=$(echo "$current_version" | cut -d. -f3)

        case "$major$minor$patch" in
            *[!0-9]*)
                echo "[auto-bump] WARNING: Non-numeric version in $current_version, skipping"
                continue
                ;;
        esac

        new_patch=$((patch + 1))
        new_version="$major.$minor.$new_patch"

        sed -i '' "s/\"version\"[[:space:]]*:[[:space:]]*\"$current_version\"/\"version\": \"$new_version\"/" "$plugin_json"

        git add "$plugin_json"

        echo "[auto-bump] $plugin_name: $current_version -> $new_version"
    fi
done

# --- Generated plugin: zelda-sounds (single source -> claude + opencode) ---
#
# zelda-sounds is compiled from the canonical source plugins/zelda-sounds/ into
# claude/zelda-sounds/ and opencode/zelda-sounds/ by `node build.mjs`. This step
# keeps the generated distributions fresh and version-consistent with the source,
# and blocks hand-edits to generated output. It is a no-op unless a zelda path is
# staged, so unrelated commits are unaffected.
zelda_source_staged=false
zelda_gen_staged=false
for f in $STAGED_FILES; do
    case "$f" in
        plugins/zelda-sounds/*)
            zelda_source_staged=true
            ;;
        claude/zelda-sounds/*|opencode/zelda-sounds/*)
            zelda_gen_staged=true
            ;;
    esac
done

if [ "$zelda_source_staged" = true ]; then
    # Canonical source changed: bump the manifest patch (mirroring the legacy
    # manual-override logic), regenerate the distributions, and stage them so the
    # commit carries version-consistent output.
    zelda_manifest="$REPO_ROOT/plugins/zelda-sounds/manifest.json"

    if [ -f "$zelda_manifest" ]; then
        current_version=$(sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$zelda_manifest")
        head_version=$(git show HEAD:plugins/zelda-sounds/manifest.json 2>/dev/null | sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')

        if [ -z "$current_version" ]; then
            echo "[zelda-sounds] WARNING: Could not read version from plugins/zelda-sounds/manifest.json, skipping bump"
        elif [ -z "$head_version" ]; then
            # New manifest (no HEAD version) — respect the authored initial version.
            :
        elif [ "$head_version" != "$current_version" ]; then
            # Version was manually changed vs HEAD — respect it.
            :
        else
            major=$(echo "$current_version" | cut -d. -f1)
            minor=$(echo "$current_version" | cut -d. -f2)
            patch=$(echo "$current_version" | cut -d. -f3)

            case "$major$minor$patch" in
                *[!0-9]*)
                    echo "[zelda-sounds] WARNING: Non-numeric version in $current_version, skipping bump"
                    ;;
                *)
                    new_patch=$((patch + 1))
                    new_version="$major.$minor.$new_patch"
                    sed -i '' "s/\"version\"[[:space:]]*:[[:space:]]*\"$current_version\"/\"version\": \"$new_version\"/" "$zelda_manifest"
                    echo "[zelda-sounds] manifest: $current_version -> $new_version"
                    ;;
            esac
        fi
    fi

    echo "[zelda-sounds] canonical source changed — running build.mjs"
    if ! ( cd "$REPO_ROOT" && node build.mjs ); then
        echo "[zelda-sounds] ERROR: build.mjs failed; aborting commit" >&2
        exit 1
    fi

    git -C "$REPO_ROOT" add plugins/zelda-sounds/manifest.json claude/zelda-sounds opencode/zelda-sounds
elif [ "$zelda_gen_staged" = true ]; then
    # Generated output staged with NO canonical source change. Rebuild and verify
    # the staged output matches a fresh build; if it differs, it was hand-edited.
    echo "[zelda-sounds] generated output staged without a source change — verifying freshness"
    if ! ( cd "$REPO_ROOT" && node build.mjs ); then
        echo "[zelda-sounds] ERROR: build.mjs failed; aborting commit" >&2
        exit 1
    fi

    if ! git -C "$REPO_ROOT" diff --quiet -- claude/zelda-sounds opencode/zelda-sounds; then
        echo "[zelda-sounds] ERROR: generated output is stale or hand-edited." >&2
        echo "  The staged claude/zelda-sounds or opencode/zelda-sounds does not match a fresh" >&2
        echo "  'node build.mjs'. Edit the canonical source under plugins/zelda-sounds/ and" >&2
        echo "  rebuild; do not hand-edit generated files." >&2
        exit 1
    fi
fi
