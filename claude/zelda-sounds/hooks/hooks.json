{
  "description": "Zelda BotW sound effects for Claude Code events",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ${CLAUDE_PLUGIN_ROOT}/sounds/Zelda-BotW-Puzzle-Solved.mp3 &"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ${CLAUDE_PLUGIN_ROOT}/sounds/Zelda-BotW-Puzzle-Solved.mp3 &"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ${CLAUDE_PLUGIN_ROOT}/sounds/Zelda-BotW-New-Location.mp3 &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ${CLAUDE_PLUGIN_ROOT}/sounds/Zelda-BotW-High-Value-Item-Get.mp3 &"
          }
        ]
      }
    ]
  }
}
