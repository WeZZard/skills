{
  "description": "Zelda sound effects for Claude Code events",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/play-configured-sound.mjs\" \"session-started\""
          }
        ],
        "matcher": "startup|resume"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/play-configured-sound.mjs\" \"task-complete\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/play-configured-sound.mjs\" \"attention-needed\""
          }
        ],
        "matcher": "AskUserQuestion"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/play-configured-sound.mjs\" \"plan-ready\""
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/play-configured-sound.mjs\" \"plan-mode-entered\""
          }
        ],
        "matcher": "EnterPlanMode"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/play-configured-sound.mjs\" \"plan-approved\""
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/play-configured-sound.mjs\" \"subagent-done\""
          }
        ],
        "matcher": ".*"
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/play-configured-sound.mjs\" \"notification\""
          }
        ],
        "matcher": ".*"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/play-configured-sound.mjs\" \"error\""
          }
        ],
        "matcher": ".*"
      }
    ]
  }
}
